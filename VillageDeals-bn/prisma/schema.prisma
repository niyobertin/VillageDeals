generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id           String    @id @default(uuid())
  firstName    String
  secondName   String
  profileImage String?
  email        String?
  gender       String
  dob          DateTime
  phoneNumber  String
  role         String    @default("USER")
  password     String
  companyId    String
  isActive     Boolean
  createdAt    DateTime  @default(now())
  updatedAt    DateTime  @updatedAt
  lastLogin    DateTime?
  shopId       String
  shop         Shop      @relation(fields: [shopId], references: [id])

  products Product[] @relation("UserProducts")

  @@map("users")
}

model Product {
  id          String   @id @default(uuid())
  name        String
  image       String?
  description String?
  categoryId  String
  price       Float
  discount    Float?
  inStock     Int
  sold        Int
  status      Boolean
  userId      String
  shopId      String
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  user            User              @relation("UserProducts", fields: [userId], references: [id])
  category        ProductCategory   @relation(fields: [categoryId], references: [id])
  shop            Shop              @relation(fields: [shopId], references: [id])
  ProductCategory ProductCategory[] @relation("ProductCategoryProducts")

  @@map("products")
}

model ProductCategory {
  id          String   @id @default(uuid())
  name        String   @unique
  description String?
  createdAt   DateTime @default(now())

  products Product[] @relation("ProductCategoryProducts")
  Product  Product[]

  @@map("products_categories")
}

model Shop {
  id          String    @id @default(uuid())
  name        String
  description String
  avatar      String?
  email       String?
  phone       String
  address     String?
  isActive    Boolean
  createdAt   DateTime  @default(now())
  updatedAt   DateTime  @updatedAt
  users       User[]
  products    Product[]

  @@map("shops")
}
